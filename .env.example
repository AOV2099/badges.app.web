BADGE_VALIDITY_DAYS=365
BADGE_PRIVATE_KEY_PATH=/app/data/signing-private-key.pem

# PostgreSQL 16
DB_HOST=localhost
DB_PORT=5432
DB_NAME=open_badges
DB_USER=badges
DB_PASSWORD=badges
DB_REQUIRED=true
DB_CONNECT_RETRIES=10
DB_RETRY_DELAY_MS=1000
DB_RETRY_MAX_DELAY_MS=10000
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# Google OAuth
# Local dev redirect URI for Vite on 5173 + backend on 3001.
# Configure this same redirect URI in Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth_google_callback.php
# Optional: restrict logins to a Google Workspace domain, for example aragon.unam.mx
GOOGLE_ALLOWED_DOMAIN=
